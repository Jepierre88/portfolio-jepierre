# SMTP settings (example values)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password

# Where contact messages should be delivered
CONTACT_TO=your.email@gmail.com

# Optional: explicit From address (must be allowed by your SMTP provider)
# CONTACT_FROM=no-reply@yourdomain.com
